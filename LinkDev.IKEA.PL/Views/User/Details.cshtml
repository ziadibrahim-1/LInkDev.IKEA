@model UserViewModel
@{
    ViewData["Title"] = "User Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4 py-lg-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 col-xl-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white p-4 border-0">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-white bg-opacity-25 d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 56px; height: 56px;">
                                <i class="fas fa-user text-white fs-4"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1">User Details</h1>
                                <p class="mb-0 text-white-50">Profile information and assigned roles</p>
                            </div>
                        </div>

                        <a asp-action="Index" class="btn btn-light btn-sm px-3">
                            <i class="fas fa-arrow-left me-1"></i> Back to List
                        </a>
                    </div>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <div class="row g-4">
                        <div class="col-12">
                            <div class="p-3 rounded-4 bg-light border">
                                <div class="row g-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="text-muted small text-uppercase fw-semibold mb-1">Full Name</div>
                                        <div class="fs-4 fw-bold">@Model.FirstName @Model.LastName</div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="text-muted small text-uppercase fw-semibold mb-1">Email</div>
                                        <div class="fw-semibold">@Model.Email</div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="text-muted small text-uppercase fw-semibold mb-1">User Id</div>
                                        <div class="text-break text-muted">@Model.Id</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <h2 class="h5 mb-0">Roles</h2>
                                <span class="badge bg-secondary rounded-pill">@Model.Roles.Count()</span>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                @if (Model.Roles.Any())
                                {
                                    foreach (var role in Model.Roles)
                                    {
                                        <span class="badge rounded-pill text-bg-primary px-3 py-2">@role</span>
                                    }
                                }
                                else
                                {
                                    <div class="alert alert-info border-0 mb-0 w-100 d-flex align-items-center gap-2">
                                        <i class="fas fa-circle-info"></i>
                                        <span>No roles assigned</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex justify-content-end gap-2 pt-2">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-success">
                                    <i class="fas fa-pen-to-square me-1"></i> Edit
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
