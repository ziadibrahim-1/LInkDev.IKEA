@model IEnumerable<UserViewModel>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/Shared/_Layout.cshtml";
	var message = TempData["Message"] as string;
	var isError = !string.IsNullOrWhiteSpace(message) &&
		(message.StartsWith("Failed", System.StringComparison.OrdinalIgnoreCase) ||
		 message.StartsWith("An error", System.StringComparison.OrdinalIgnoreCase) ||
		 message.StartsWith("Invalid", System.StringComparison.OrdinalIgnoreCase) ||
		 message.StartsWith("User with id", System.StringComparison.OrdinalIgnoreCase));
}

<div class="container py-4">
	@if (!string.IsNullOrWhiteSpace(message))
	{
		<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;">
			<div class="toast fade show border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="5000">
				<div class="toast-header @(isError ? "bg-danger text-white" : "bg-success text-white") border-0">
					<i class="fas @(isError ? "fa-circle-xmark" : "fa-circle-check") me-2"></i>
					<strong class="me-auto">@(isError ? "Error" : "Success")</strong>
					<small class="text-white-50">Just now</small>
					<button type="button" class="btn-close btn-close-white ms-2 mb-1" data-bs-dismiss="toast" aria-label="Close"></button>
				</div>
				<div class="toast-body bg-white">
					<div class="d-flex align-items-start gap-3">
						<div class="rounded-circle @(isError ? "bg-danger-subtle text-danger" : "bg-success-subtle text-success") d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px;">
							<i class="fas @(isError ? "fa-triangle-exclamation" : "fa-check")"></i>
						</div>
						<div>
							<div class="fw-semibold @(isError ? "text-danger" : "text-success") mb-1">@(isError ? "Operation failed" : "Operation completed")</div>
							<div class="text-muted">@message</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	}

	<h1>All Users</h1>
	<br />
	<br />
	<div class="m-2">
		<form class="row offset-2" asp-action="Index" method="get">
			<div class="col-8">
				<input class="form-control" type="text" name="SearchValue" placeholder="Search by user email" />
			</div>
			<div class="col-4">
				<input type="submit" class="btn btn-outline-dark" value="Search" />
			</div>
		</form>
	</div>
	@if (Model.Count() > 0)
	{
		<table class="table table-striped table-hover mt-3">
			<thead class="text-center">
				<tr>
					<th>@Html.DisplayNameFor(u => u.Id)</th>
					<th>@Html.DisplayNameFor(u => u.FirstName)</th>
					<th>@Html.DisplayNameFor(u => u.LastName)</th>
					<th>@Html.DisplayNameFor(u => u.Email)</th>
					<th>@Html.DisplayNameFor(u => u.Roles)</th>
					<th>Details </th>
					<th>Update</th>
					<th>Delete</th>
				</tr>
			</thead>
			<tbody class="text-center">
				@foreach (var user in Model)
				{
					<tr>
						<td>@user.Id</td>
						<td>@user.FirstName</td>
						<td>@user.LastName</td>
						<td>@user.Email</td>
						<td>@string.Join(",", user.Roles)</td>
						<partial name="_ButtonsPartialView" model="@user.Id" />
						<td>
							<button type="button" class="btn btn-danger js-delete-user" data-bs-toggle="modal" data-bs-target="#deleteUserModal" data-user-id="@user.Id" data-user-name="@user.FirstName" data-user-email="@user.Email">
								<i class="fas fa-trash"></i> Delete
							</button>
						</td>
					</tr>

				}
			</tbody>
		</table>

		<!-- Single reusable delete modal for users (mirrors Employee Index behavior) -->
		<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
			<div class="modal-dialog modal-dialog-centered">
				<div class="modal-content border-0 shadow-lg rounded-4">
					<div class="modal-header bg-danger text-white border-0 rounded-top-4">
						<h5 class="modal-title" id="deleteUserModalLabel">
							<i class="fas fa-triangle-exclamation me-2"></i> Delete User
						</h5>
						<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>
					<div class="modal-body">
						<p class="mb-2">Are you sure you want to delete this user?</p>
						<div class="alert alert-warning mb-0">
							<div class="fw-semibold" id="deleteUserName"></div>
							<div class="text-muted small" id="deleteUserEmail"></div>
						</div>
					</div>
					<div class="modal-footer border-0 pt-0">
						<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
						<form asp-action="Delete" method="post" class="d-inline">
							@Html.AntiForgeryToken()
							<input type="hidden" name="id" id="deleteUserId" />
							<button type="submit" class="btn btn-danger">
								<i class="fas fa-trash me-1"></i> Delete
							</button>
						</form>
					</div>
				</div>
			</div>
		</div>

	}
	else
	{
		<div class="alert alert-info mt-3">
			<h2>No Users Found !!</h2>
		</div>
	}
</div>

@section Scripts {
	<script>
		(function () {
			var deleteUserId = document.getElementById('deleteUserId');
			var deleteUserName = document.getElementById('deleteUserName');
			var deleteUserEmail = document.getElementById('deleteUserEmail');
			var deleteUserModal = document.getElementById('deleteUserModal');

			document.querySelectorAll('.js-delete-user').forEach(function (button) {
				button.addEventListener('click', function () {
					if (deleteUserId) deleteUserId.value = this.dataset.userId || '';
					if (deleteUserName) deleteUserName.textContent = this.dataset.userName || '';
					if (deleteUserEmail) deleteUserEmail.textContent = this.dataset.userEmail || '';
				});
			});

			if (deleteUserModal) {
				deleteUserModal.addEventListener('hidden.bs.modal', function () {
					if (deleteUserId) deleteUserId.value = '';
					if (deleteUserName) deleteUserName.textContent = '';
					if (deleteUserEmail) deleteUserEmail.textContent = '';
				});
			}

			// Initialize Bootstrap toasts and auto-hide after 5 seconds
			document.querySelectorAll('.toast').forEach(function (toastEl) {
				try {
					var bsToast = new bootstrap.Toast(toastEl, { autohide: true, delay: 5000 });
					bsToast.show();
				} catch (e) {
					// ignore if bootstrap is not available
				}
			});

		})();
	</script>
}
