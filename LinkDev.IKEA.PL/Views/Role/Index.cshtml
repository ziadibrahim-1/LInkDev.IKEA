@using LinkDev.IKEA.PL.Models.Roles
@model IEnumerable<RoleViewModel>
@{
    ViewData["Title"] = "Roles";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var message = TempData["Message"] as string;
    var isError = !string.IsNullOrWhiteSpace(message) &&
        (message.StartsWith("Failed", System.StringComparison.OrdinalIgnoreCase) ||
         message.StartsWith("An error", System.StringComparison.OrdinalIgnoreCase) ||
         message.StartsWith("Invalid", System.StringComparison.OrdinalIgnoreCase));
}

<div class="container py-4">
    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;">
            <div class="toast fade show border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header @(isError ? "bg-danger text-white" : "bg-success text-white") border-0">
                    <i class="fas @(isError ? "fa-circle-xmark" : "fa-circle-check") me-2"></i>
                    <strong class="me-auto">@(isError ? "Error" : "Success")</strong>
                    <small class="text-white-50">Just now</small>
                    <button type="button" class="btn-close btn-close-white ms-2 mb-1" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body bg-white">
                    <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle @(isError ? "bg-danger-subtle text-danger" : "bg-success-subtle text-success") d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px;">
                            <i class="fas @(isError ? "fa-triangle-exclamation" : "fa-check")"></i>
                        </div>
                        <div>
                            <div class="fw-semibold @(isError ? "text-danger" : "text-success") mb-1">@(isError ? "Operation failed" : "Operation completed")</div>
                            <div class="text-muted">@message</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="mb-0 fw-bold">Roles</h2>
            <small class="text-muted">Manage system roles and permissions.</small>
        </div>

        <div class="d-flex align-items-center w-100">
            <div class="d-flex gap-2 align-items-center flex-grow-1">
                <form asp-action="Index" method="get" class="d-flex align-items-center">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="SearchValue" class="form-control border-start-0" placeholder="Search roles...">
                        <button class="btn btn-outline-secondary" type="submit">Search</button>
                        <button type="button" class="btn btn-outline-light" id="clearSearch" title="Clear search"><i class="fas fa-times text-muted"></i></button>
                    </div>
                </form>
            </div>

            <a asp-action="Create" class="btn btn-primary btn-lg ms-auto shadow-sm">
                <i class="fas fa-plus me-1"></i> Create New Role
            </a>
        </div>
    </div>

    <div class="card shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model.Count() > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-muted small">
                            <tr>
                                <th class="ps-4">Role Name</th>
                                <th class="text-center">Role ID</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;font-weight:600;">
                                                <i class="fas fa-lock"></i>
                                            </div>
                                            <div>
                                                <div class="fw-semibold">@role.Name</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center text-muted small">
                                        <code>@role.Id.Substring(0, Math.Min(8, role.Id.Length))...</code>
                                    </td>
                                    <partial name="_ButtonsPartialView" model="@role.Id" />
                                    <td class="text-end pe-4">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger js-delete-role"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteRoleModal"
                                                data-role-id="@role.Id"
                                                data-role-name="@role.Name">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-5 text-center">
                    <div class="mb-3">
                        <i class="fas fa-inbox text-muted" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="text-muted">No Roles Found</h5>
                    <p class="text-muted small">There are no roles to display. Create a new role to get started.</p>
                    <a asp-action="Create" class="btn btn-primary btn-sm mt-2">
                        <i class="fas fa-plus me-1"></i> Create New Role
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Delete Role Modal -->
    <div class="modal fade" id="deleteRoleModal" tabindex="-1" aria-labelledby="deleteRoleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-danger text-white border-0 rounded-top-4">
                    <h5 class="modal-title" id="deleteRoleModalLabel">
                        <i class="fas fa-triangle-exclamation me-2"></i> Delete Role
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">Are you sure you want to delete this role?</p>
                    <div class="alert alert-warning mb-0">
                        <div class="fw-semibold" id="deleteRoleName"></div>
                        <div class="text-muted small" id="deleteRoleId"></div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="Delete" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="deleteRoleId_input" />
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash me-1"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        (function () {
            var btnClear = document.getElementById('clearSearch');
            if (btnClear) {
                btnClear.addEventListener('click', function (e) {
                    e.preventDefault();
                    var input = document.querySelector('input[name="SearchValue"]');
                    if (input) input.value = '';
                    var form = this.closest('form');
                    if (form) form.submit();
                });
            }

            var deleteRoleId_input = document.getElementById('deleteRoleId_input');
            var deleteRoleName = document.getElementById('deleteRoleName');
            var deleteRoleId_display = document.getElementById('deleteRoleId');
            var deleteRoleModal = document.getElementById('deleteRoleModal');

            document.querySelectorAll('.js-delete-role').forEach(function (button) {
                button.addEventListener('click', function () {
                    if (deleteRoleId_input) deleteRoleId_input.value = this.dataset.roleId || '';
                    if (deleteRoleName) deleteRoleName.textContent = this.dataset.roleName || '';
                    if (deleteRoleId_display) deleteRoleId_display.textContent = 'ID: ' + (this.dataset.roleId || '');
                });
            });

            if (deleteRoleModal) {
                deleteRoleModal.addEventListener('hidden.bs.modal', function () {
                    if (deleteRoleId_input) deleteRoleId_input.value = '';
                    if (deleteRoleName) deleteRoleName.textContent = '';
                    if (deleteRoleId_display) deleteRoleId_display.textContent = '';
                });
            }

            // Initialize Bootstrap toasts and auto-hide after 5 seconds
            document.querySelectorAll('.toast').forEach(function (toastEl) {
                try {
                    var bsToast = new bootstrap.Toast(toastEl, { autohide: true, delay: 5000 });
                    bsToast.show();
                } catch (e) {
                    // ignore if bootstrap is not available
                }
            });

        })();
    </script>
}


