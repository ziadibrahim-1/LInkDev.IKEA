@model RoleViewModel
@{
    ViewData["Title"] = "Create Role";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4 py-lg-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-9 col-xl-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-success text-white p-4 border-0">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-white bg-opacity-25 d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 56px; height: 56px;">
                                <i class="fas fa-plus fs-4"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1">Create New Role</h1>
                                <p class="mb-0 text-white-50">Add a new system role to manage permissions</p>
                            </div>
                        </div>

                        <a asp-action="Index" class="btn btn-light btn-sm px-3">
                            <i class="fas fa-arrow-left me-1"></i> Back to List
                        </a>
                    </div>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0"></div>

                        <div class="row g-4">
                            <div class="col-12">
                                <label asp-for="Name" class="form-label fw-semibold">Role Name</label>
                                <input asp-for="Name" class="form-control form-control-lg" placeholder="e.g., Administrator, Manager, Editor" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                                <small class="text-muted d-block mt-2">
                                    <i class="fas fa-info-circle me-1"></i>
                                    Enter a descriptive role name (e.g., Administrator, Manager, User)
                                </small>
                            </div>

                            <div class="col-12">
                                <div class="alert alert-info border-0 d-flex align-items-start gap-3 mb-0">
                                    <div class="flex-shrink-0">
                                        <i class="fas fa-lightbulb fs-5"></i>
                                    </div>
                                    <div>
                                        <h5 class="alert-heading mb-1">Best Practices</h5>
                                        <ul class="mb-0 small ps-3">
                                            <li>Use clear and concise role names</li>
                                            <li>Avoid special characters or spaces</li>
                                            <li>Keep role names in singular form (e.g., "Admin" instead of "Admins")</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="d-flex justify-content-end gap-2 pt-2">
                                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                        Cancel
                                    </a>
                                    <button type="submit" class="btn btn-success px-4 fw-semibold">
                                        <i class="fas fa-plus me-1"></i> Create Role
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

