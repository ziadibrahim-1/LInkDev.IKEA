
@model string
@{
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
}

<td>
    <a class="btn btn-outline-info btn-sm px-3" asp-controller="@controllerName" asp-action="Details" asp-route-id="@Model">
        <i class="fas fa-eye me-1"></i> Details
    </a>
</td>
<td>
    <a class="btn btn-outline-warning btn-sm px-3" asp-controller="@controllerName" asp-action="Edit" asp-route-id="@Model">
        <i class="fas fa-pen-to-square me-1"></i> Update
    </a>
</td>
