
@model IEnumerable<DepartmentViewModel>
@{
    ViewData["Title"] = "Department";
    var message = TempData["Message"] as string;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h1 class="mb-1 fw-bold">Departments</h1>
            <p class="text-muted mb-0">Manage department records and review their details.</p>
        </div>

        <a class="btn btn-primary btn-lg shadow-sm" asp-controller="Department" asp-action="Create">
            <i class="fas fa-plus me-1"></i> Create New Department
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;">
            <div class="toast fade show border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header bg-success text-white border-0">
                    <i class="fas fa-circle-check me-2"></i>
                    <strong class="me-auto">Success</strong>
                    <small class="text-white-50">Just now</small>
                    <button type="button" class="btn-close btn-close-white ms-2 mb-1" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body bg-white">
                    <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle bg-success-subtle text-success d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px;">
                            <i class="fas fa-check"></i>
                        </div>
                        <div>
                            <div class="fw-semibold text-success mb-1">Operation completed</div>
                            <div class="text-muted">@message</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.Any())
    {
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-center">
                        <tr>
                            <th>@Html.DisplayNameFor(d => d.Code)</th>
                            <th>@Html.DisplayNameFor(d => d.Name)</th>
                            <th>@Html.DisplayNameFor(d => d.CreationDate)</th>
                            <th>Details</th>
                            <th>Update</th>
                            <th>Delete</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        @foreach (var department in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@department.Code</td>
                                <td>@department.Name</td>
                                <td>@department.CreationDate</td>
                                <td>
                                    <a class="btn btn-outline-info btn-sm px-3" asp-controller="Department" asp-action="Details" asp-route-id="@department.Id">
                                        <i class="fas fa-eye me-1"></i> Details
                                    </a>
                                </td>
                                <td>
                                    <a class="btn btn-outline-warning btn-sm px-3" asp-controller="Department" asp-action="Edit" asp-route-id="@department.Id">
                                        <i class="fas fa-pen-to-square me-1"></i> Update
                                    </a>
                                </td>
                                <td>
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm px-3 js-delete-department"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteDepartmentModal"
                                            data-department-id="@department.Id"
                                            data-department-code="@department.Code"
                                            data-department-name="@department.Name">
                                        <i class="fas fa-trash me-1"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-primary border-0 shadow-sm mt-4 d-flex align-items-center gap-2">
            <i class="fas fa-circle-info"></i>
            <span>There is no department to display.</span>
        </div>
    }
</div>

<div class="modal fade" id="deleteDepartmentModal" tabindex="-1" aria-labelledby="deleteDepartmentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-danger text-white border-0 rounded-top-4">
                <h5 class="modal-title" id="deleteDepartmentModalLabel">
                    <i class="fas fa-triangle-exclamation me-2"></i> Delete Department
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">Are you sure you want to delete this department?</p>
                <div class="alert alert-warning mb-0">
                    <div class="fw-semibold" id="deleteDepartmentName"></div>
                    <div class="text-muted small" id="deleteDepartmentCode"></div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-controller="Department" asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteDepartmentId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var modal = document.getElementById('deleteDepartmentModal');
            var deleteDepartmentId = document.getElementById('deleteDepartmentId');
            var deleteDepartmentName = document.getElementById('deleteDepartmentName');
            var deleteDepartmentCode = document.getElementById('deleteDepartmentCode');

            document.querySelectorAll('.js-delete-department').forEach(function (button) {
                button.addEventListener('click', function () {
                    deleteDepartmentId.value = this.dataset.departmentId || '';
                    deleteDepartmentName.textContent = this.dataset.departmentName || '';
                    deleteDepartmentCode.textContent = this.dataset.departmentCode ? 'Code: ' + this.dataset.departmentCode : '';
                });
            });

            modal.addEventListener('hidden.bs.modal', function () {
                deleteDepartmentId.value = '';
                deleteDepartmentName.textContent = '';
                deleteDepartmentCode.textContent = '';
            });
        });
    </script>
}

