@model CreateDepartmentViewModel
@{
    ViewData["Title"] = "Create";
}

<div class="container py-4">
    <div class="row justify-content-center g-4">
        <div class="col-12 col-lg-10 col-xl-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden position-relative">
                <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, rgba(13,110,253,.12), rgba(13,110,253,0)); pointer-events:none;"></div>

                <div class="card-header bg-primary bg-gradient text-white py-4 position-relative">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div>
                            <div class="badge text-bg-light text-primary px-3 py-2 mb-2">Department</div>
                            <h1 class="h3 fw-bold mb-1">Create New Department</h1>
                            <p class="mb-0 text-white-50">Add a new department record to the system.</p>
                        </div>
                        <div class="rounded-circle bg-white bg-opacity-25 d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 72px; height: 72px;">
                            <i class="fas fa-folder-plus fa-2x text-white"></i>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post" novalidate>
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm mb-4"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Code" class="form-label fw-semibold text-primary"></label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-primary-subtle border-primary-subtle border-end-0">
                                        <i class="fas fa-barcode text-primary"></i>
                                    </span>
                                    <input asp-for="Code" class="form-control border-start-0" placeholder="Department code" />
                                </div>
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-semibold text-primary"></label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-primary-subtle border-primary-subtle border-end-0">
                                        <i class="fas fa-building text-primary"></i>
                                    </span>
                                    <input asp-for="Name" class="form-control border-start-0" placeholder="Department name" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold text-primary"></label>
                                <textarea asp-for="Description" class="form-control shadow-sm" rows="5" placeholder="Describe this department"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="CreationDate" class="form-label fw-semibold text-primary"></label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-primary-subtle border-primary-subtle border-end-0">
                                        <i class="fas fa-calendar-day text-primary"></i>
                                    </span>
                                    <input asp-for="CreationDate" class="form-control border-start-0" type="date" />
                                </div>
                                <span asp-validation-for="CreationDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-5 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="fas fa-arrow-left me-1"></i> Back to List
                            </a>

                            <button type="submit" class="btn btn-outline-primary btn-lg px-4 shadow-lg shadow-sm">
                                <i class="fas fa-plus me-1"></i> Create Department
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
